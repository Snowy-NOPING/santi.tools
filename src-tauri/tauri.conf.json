{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "santi.tools",
  "version": "1.6.0",
  "identifier": "com.santi.tools",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "santi.tools",
        "width": 1000,
        "height": 700,
        "minWidth": 600,
        "minHeight": 500,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/yt-dlp"
    ]
  }
}
